# BookStack MCP Server - Environment Configuration
# Copy this file to .env and fill in your values

# Required: Your BookStack instance URL (must include /api)
BOOKSTACK_BASE_URL=https://your-bookstack.com/api

# Required: Your BookStack API token (format: token_id:token_secret)
# Create one at: Your Profile -> API Tokens in BookStack
BOOKSTACK_API_TOKEN=your_token_id:your_token_secret

# Optional: Request timeout in milliseconds (default: 30000)
BOOKSTACK_TIMEOUT=30000
